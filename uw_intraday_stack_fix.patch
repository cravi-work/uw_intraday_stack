+def _load_feature_rows_for_snapshot(conn: duckdb.DuckDBPyConnection, snapshot_id: int) -> List[Dict[str, Any]]:
+    """Fallback feature source for replay.
+
+    Some unit tests (and certain offline ingestion paths) can persist feature rows without
+    persisting raw endpoint payload/lineage. In those cases, replay cannot re-extract
+    features from payloads and should instead use the stored feature table.
+    """
+
+    try:
+        rows = conn.execute(
+            "SELECT feature_key, feature_value, meta_json FROM features WHERE snapshot_id = ? ORDER BY feature_key",
+            [snapshot_id],
+        ).fetchall()
+    except Exception:
+        return []
+
+    out: List[Dict[str, Any]] = []
+    for feature_key, feature_value, meta_json in rows or []:
+        meta: Dict[str, Any]
+        if meta_json is None:
+            meta = {}
+        elif isinstance(meta_json, dict):
+            meta = dict(meta_json)
+        elif isinstance(meta_json, str):
+            meta = _safe_json_loads(meta_json)
+        else:
+            meta = {}
+
+        out.append(
+            {
+                "feature_key": str(feature_key),
+                "feature_value": feature_value,
+                "meta_json": meta,
+            }
+        )
+    return out
+
